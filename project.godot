; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Pokemon Fangame"
run/main_scene="res://scenes/ui/title_screen.tscn"
config/features=PackedStringArray("4.7")
config/icon="res://icon.svg"

[autoload]

Transitions="*res://scripts/transitions.gd"
PlayerData="*res://scripts/player_data.gd"
SafariState="*res://scripts/safari_state.gd"
MapNames="*res://scripts/map_names.gd"
ScreenFade="*res://scripts/screen_fade.gd"
SaveManager="*res://scripts/save_manager.gd"
KeyBindings="*res://scripts/key_bindings.gd"

; Les 4 actions existent ici (nécessaire pour qu'Input/InputMap les
; connaissent dès le boot), mais sans événement par défaut : la vraie touche
; de départ (F1-F4) est posée au runtime par scripts/key_bindings.gd
; (KeyBindings.DEFAULT_KEYCODES), pas ici — ça évite d'avoir deux sources de
; vérité qui peuvent diverger (vécu : ce fichier disait encore 1/2/3/4 après
; le passage à F1-F4 côté script).
[input]

item_shortcut_1={
"deadzone": 0.5,
"events": []
}
item_shortcut_2={
"deadzone": 0.5,
"events": []
}
item_shortcut_3={
"deadzone": 0.5,
"events": []
}
item_shortcut_4={
"deadzone": 0.5,
"events": []
}
