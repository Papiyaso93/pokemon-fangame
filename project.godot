; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Pokemon Fangame"
run/main_scene="res://scenes/intro/intro.tscn"
config/features=PackedStringArray("4.7")
config/icon="res://icon.svg"

[autoload]

Transitions="*res://scripts/transitions.gd"
PlayerData="*res://scripts/player_data.gd"
SafariState="*res://scripts/safari_state.gd"
MapNames="*res://scripts/map_names.gd"
