[gd_scene load_steps=5 format=3]

[ext_resource type="Script" path="res://scripts/save_slots.gd" id="1_script"]
[ext_resource type="Texture2D" path="res://assets/ui/std_window.png" id="2_window"]

[sub_resource type="StyleBoxTexture" id="WindowStyle"]
texture = ExtResource("2_window")
texture_margin_left = 16.0
texture_margin_top = 16.0
texture_margin_right = 16.0
texture_margin_bottom = 16.0

[sub_resource type="Theme" id="TitleTheme"]
Label/font_sizes/font_size = 24
Label/colors/font_color = Color(0.1, 0.1, 0.1, 1)

[sub_resource type="Theme" id="ButtonTheme"]
Button/colors/font_color = Color(0.1, 0.1, 0.1, 1)
Button/colors/font_hover_color = Color(0.1, 0.1, 0.1, 1)
Button/font_sizes/font_size = 16

[node name="SaveSlots" type="CanvasLayer"]
script = ExtResource("1_script")

[node name="Root" type="Control" parent="."]
anchor_right = 1.0
anchor_bottom = 1.0

[node name="Center" type="CenterContainer" parent="Root"]
anchor_right = 1.0
anchor_bottom = 1.0

[node name="Window" type="PanelContainer" parent="Root/Center"]
theme_override_styles/panel = SubResource("WindowStyle")

[node name="Margin" type="MarginContainer" parent="Root/Center/Window"]
layout_mode = 2
theme_override_constants/margin_left = 24
theme_override_constants/margin_top = 20
theme_override_constants/margin_right = 24
theme_override_constants/margin_bottom = 20

[node name="Content" type="VBoxContainer" parent="Root/Center/Window/Margin"]
layout_mode = 2
theme_override_constants/separation = 14

[node name="Title" type="Label" parent="Root/Center/Window/Margin/Content"]
layout_mode = 2
theme = SubResource("TitleTheme")
text = "Charger une partie"
horizontal_alignment = 1

[node name="Rows" type="VBoxContainer" parent="Root/Center/Window/Margin/Content"]
layout_mode = 2
theme = SubResource("ButtonTheme")
theme_override_constants/separation = 8

[node name="Back" type="Button" parent="Root/Center/Window/Margin/Content"]
layout_mode = 2
theme = SubResource("ButtonTheme")
text = "Revenir"

[connection signal="pressed" from="Root/Center/Window/Margin/Content/Back" to="." method="_on_back_pressed"]
