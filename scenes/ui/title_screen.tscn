[gd_scene load_steps=5 format=3]

[ext_resource type="Script" path="res://scripts/title_screen.gd" id="1_script"]
[ext_resource type="Texture2D" path="res://assets/ui/std_window.png" id="2_window"]

[sub_resource type="StyleBoxTexture" id="WindowStyle"]
texture = ExtResource("2_window")
texture_margin_left = 16.0
texture_margin_top = 16.0
texture_margin_right = 16.0
texture_margin_bottom = 16.0

[sub_resource type="Theme" id="TitleTheme"]
Label/font_sizes/font_size = 32
Label/colors/font_color = Color(1, 1, 1, 1)

[node name="TitleScreen" type="CanvasLayer"]
script = ExtResource("1_script")

[node name="Root" type="Control" parent="."]
anchor_right = 1.0
anchor_bottom = 1.0

[node name="Background" type="ColorRect" parent="Root"]
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0.11, 0.16, 0.28, 1)

[node name="GameTitle" type="Label" parent="Root"]
anchor_left = 0.5
anchor_right = 0.5
offset_left = -200.0
offset_top = 60.0
offset_right = 200.0
offset_bottom = 110.0
theme = SubResource("TitleTheme")
text = "Pokémon Fangame"
horizontal_alignment = 1

[node name="Center" type="CenterContainer" parent="Root"]
anchor_right = 1.0
anchor_bottom = 1.0

[node name="Window" type="PanelContainer" parent="Root/Center"]
theme_override_styles/panel = SubResource("WindowStyle")

[node name="Buttons" type="VBoxContainer" parent="Root/Center/Window"]
layout_mode = 2
theme_override_constants/separation = 10

[node name="NewGame" type="Button" parent="Root/Center/Window/Buttons"]
layout_mode = 2
custom_minimum_size = Vector2(240, 0)
text = "Nouvelle partie"

[node name="LoadGame" type="Button" parent="Root/Center/Window/Buttons"]
layout_mode = 2
custom_minimum_size = Vector2(240, 0)
text = "Charger une partie"

[node name="Tests" type="Button" parent="Root/Center/Window/Buttons"]
layout_mode = 2
custom_minimum_size = Vector2(240, 0)
text = "Tests"

[connection signal="pressed" from="Root/Center/Window/Buttons/NewGame" to="." method="_on_new_game_pressed"]
[connection signal="pressed" from="Root/Center/Window/Buttons/LoadGame" to="." method="_on_load_game_pressed"]
[connection signal="pressed" from="Root/Center/Window/Buttons/Tests" to="." method="_on_tests_pressed"]
