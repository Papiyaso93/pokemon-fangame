[gd_scene load_steps=5 format=3]

[ext_resource type="Script" path="res://scripts/class_choice.gd" id="1_script"]
[ext_resource type="Texture2D" path="res://assets/ui/dialogue_frame.png" id="2_window"]

[sub_resource type="StyleBoxTexture" id="WindowStyle"]
texture = ExtResource("2_window")
texture_margin_left = 48.0
texture_margin_top = 24.0
texture_margin_right = 48.0
texture_margin_bottom = 24.0
content_margin_left = 30.0
content_margin_top = 20.0
content_margin_right = 30.0
content_margin_bottom = 20.0
axis_stretch_horizontal = 1
axis_stretch_vertical = 0

[sub_resource type="StyleBoxEmpty" id="Btn_empty"]
content_margin_left = 8.0
content_margin_top = 6.0
content_margin_right = 8.0
content_margin_bottom = 6.0

[sub_resource type="Theme" id="ChoiceTheme"]
Button/styles/normal = SubResource("Btn_empty")
Button/styles/hover = SubResource("Btn_empty")
Button/styles/pressed = SubResource("Btn_empty")
Button/styles/focus = SubResource("Btn_empty")
Button/colors/font_color = Color(0.1, 0.1, 0.1, 1)
Button/colors/font_hover_color = Color(0.1, 0.1, 0.1, 1)
Button/font_sizes/font_size = 20

[node name="ClassChoice" type="CanvasLayer"]
script = ExtResource("1_script")

[node name="Root" type="Control" parent="."]
anchor_right = 1.0
anchor_bottom = 1.0

[node name="Window" type="PanelContainer" parent="Root"]
theme_override_styles/panel = SubResource("WindowStyle")

[node name="Buttons" type="VBoxContainer" parent="Root/Window"]
layout_mode = 2
theme = SubResource("ChoiceTheme")
theme_override_constants/separation = 8

[node name="Competiteur" type="Button" parent="Root/Window/Buttons"]
layout_mode = 2
custom_minimum_size = Vector2(200, 0)
icon_alignment = 0
expand_icon = false
text = "Compétiteur"

[node name="Chercheur" type="Button" parent="Root/Window/Buttons"]
layout_mode = 2
custom_minimum_size = Vector2(200, 0)
icon_alignment = 0
expand_icon = false
text = "Chercheur"

[node name="Repeat" type="Button" parent="Root/Window/Buttons"]
layout_mode = 2
custom_minimum_size = Vector2(200, 0)
icon_alignment = 0
expand_icon = false
text = "Peux-tu répéter ?"

[connection signal="pressed" from="Root/Window/Buttons/Competiteur" to="." method="_on_competiteur_pressed"]
[connection signal="pressed" from="Root/Window/Buttons/Chercheur" to="." method="_on_chercheur_pressed"]
[connection signal="pressed" from="Root/Window/Buttons/Repeat" to="." method="_on_repeat_pressed"]
